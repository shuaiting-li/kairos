{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"files": {
		"includes": [
			"src/**/*.ts",
			"*.ts",
			"*.js",
			"*.json",
			"!node_modules",
			"!dist",
			"!build",
			"!.svelte-kit",
			"!src-tauri/target",
			"!src-tauri/gen"
		]
	}
}
